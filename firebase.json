{
  "hosting": {
    "site": "acr-site",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "CNAME",
      ".git/**"
    ],
    "headers": [
      {
        "source": "**/*.@(webp|png|jpg|gif)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
        ]
      }
    ],
    "cleanUrls": true
  }
}
